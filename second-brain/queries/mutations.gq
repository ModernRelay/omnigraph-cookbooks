// ──────────────────────────────────────────────
// Provenance
// ──────────────────────────────────────────────

query link_mentions_person($artifact: String, $person: String) {
    insert MentionsPerson { from: $artifact, to: $person }
}

query link_artifact_from_person($artifact: String, $person: String) {
    insert ArtifactFromPerson { from: $artifact, to: $person }
}

query link_artifact_for_project($artifact: String, $project: String) {
    insert ArtifactForProject { from: $artifact, to: $project }
}

query link_record_of($artifact: String, $event: String) {
    insert RecordOf { from: $artifact, to: $event }
}

query link_in_reply_to($from: String, $to: String) {
    insert InReplyTo { from: $from, to: $to }
}

query link_derived_from($from: String, $to: String, $activity: String, $createdAt: DateTime) {
    insert DerivedFromArtifact { from: $from, to: $to, activity: $activity, createdAt: $createdAt }
}
