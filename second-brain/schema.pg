// Second Brain — Personal Life Ontology
// A minimal-but-comprehensive Omnigraph schema for individuals.
//
// Layered into six concerns:
//   1. People & Roles           — Person, Organization
//   2. World & Time             — Place, Event
//   3. Capture                  — Note
//   4. Action & Structure       — Task, Project, Area, Goal, Habit
//   5. Media                    — Media
//   6. Provenance & Search      — Artifact, Chunk
//
// Slug prefix convention:
//   per-   Person          (per-self = "me")
//   org-   Organization
//   pl-    Place
//   ev-    Event
//   nt-    Note
//   tk-    Task
//   proj-  Project
//   area-  Area
//   goal-  Goal
//   hab-   Habit
//   med-   Media
//   art-   Artifact


// ──────────────────────────────────────────────
// People & Roles
// ──────────────────────────────────────────────

// "Me" is the Person with slug "per-self" and relation = self.
node Person {
    slug: String @key
    name: String @index
    first_name: String?
    last_name: String?
    relation: enum(self, family, partner, close-friend, friend, colleague, mentor, mentee, acquaintance, professional) @index
    email: String?
    phone: String?
    birthday: Date?
    location: String?
    current_role: String?
    // Desired contact frequency in days. Drives stale-relationship queries.
    cadence_days: I32?
    how_met: String?
    brief: String?
    createdAt: DateTime
    updatedAt: DateTime
}

node Organization {
    slug: String @key
    name: String @index
    kind: enum(company, school, club, community, nonprofit, government, team) @index
    brief: String?
    website: String?
    createdAt: DateTime
    updatedAt: DateTime
}


// ──────────────────────────────────────────────
// World & Time
// ──────────────────────────────────────────────

node Place {
    slug: String @key
    name: String @index
    kind: enum(city, country, neighborhood, restaurant, cafe, office, home, venue, airport, park, gym, school, other) @index
    address: String?
    lat: F64?
    lng: F64?
    brief: String?
    createdAt: DateTime
    updatedAt: DateTime
}

// Event covers anything time-stamped: meetings, milestones, life-events for self or others.
// Use kind = life-event for things like "Sarah's wedding" or "Dad's surgery" — the person
// it affects is linked via EventForPerson, not via AttendedBy.
node Event {
    slug: String @key
    name: String @index
    kind: enum(meeting, call, dinner, party, trip, milestone, birthday, anniversary, life-event, workout, conference, date, hangout, deadline, other) @index
    when: DateTime @index
    end_at: DateTime?
    mood: enum(great, good, neutral, mixed, hard)?
    brief: String?
    description: String?
    tags: [String]?
    createdAt: DateTime
    updatedAt: DateTime
}


// ──────────────────────────────────────────────
// Capture
// ──────────────────────────────────────────────

// One Note type carries every captured thought. The kind enum is what makes
// "journal entry," "principle," "preference about Sarah" distinguishable in queries.
//
// LLM guidance: Notes should be atomic — one idea, one principle, one insight per node.
// Use RelatedNote to connect rather than concatenating.
node Note {
    slug: String @key
    name: String @index
    kind: enum(idea, journal, reflection, insight, principle, preference, quote, dream, question, decision) @index
    content: String?
    when: Date?
    tags: [String]?
    createdAt: DateTime
    updatedAt: DateTime
}


// ──────────────────────────────────────────────
// Action & Structure (GTD + PARA + Atomic Habits)
// ──────────────────────────────────────────────

// Task follows GTD. New tasks land in "inbox," then get clarified into a status.
// direction tracks relationship debts — "i-owe Theo a book recommendation."
node Task {
    slug: String @key
    name: String @index
    status: enum(inbox, next, waiting, someday, done, cancelled) @index
    kind: enum(action, research, decision, waiting, reminder, admin)?
    context: enum(phone, computer, errand, home, office, anywhere)?
    priority: enum(low, medium, high, critical)?
    due: DateTime?
    remind_at: DateTime?
    direction: enum(i-owe, they-owe, mutual)?
    waiting_on: String?
    brief: String?
    tags: [String]?
    createdAt: DateTime
    updatedAt: DateTime
}

// Project = bounded effort with an end state. "exploring" subsumes Opportunity-style entries
// (things I'm considering but haven't committed to).
node Project {
    slug: String @key
    name: String @index
    kind: enum(work, personal, hobby, side-project, learning, health, home, family) @index
    status: enum(exploring, active, paused, completed, abandoned) @index
    brief: String?
    description: String?
    due: Date?
    createdAt: DateTime
    updatedAt: DateTime
}

// Area = ongoing life domain with no end date. Health, career, family, etc.
node Area {
    slug: String @key
    name: String @index
    kind: enum(health, career, finance, relationships, learning, creativity, community, spirituality, home, family, other) @index
    status: enum(active, archived) @index
    brief: String?
    createdAt: DateTime
    updatedAt: DateTime
}

// Goal = a desired outcome with a timeframe. Distinct from Project (Project = deliverable).
node Goal {
    slug: String @key
    name: String @index
    status: enum(active, achieved, abandoned, paused) @index
    timeframe: enum(quarterly, yearly, multi-year)?
    target: String?
    due: Date?
    brief: String?
    createdAt: DateTime
    updatedAt: DateTime
}

// Atomic Habits: cue → routine → reward. Completions are a date array; loses per-completion
// detail but keeps the schema small. Promote to HabitCompletion node only if you need it.
node Habit {
    slug: String @key
    name: String @index
    status: enum(active, paused, dropped) @index
    frequency: enum(daily, weekly, monthly) @index
    cue: String?
    routine: String?
    reward: String?
    completions: [Date]?
    streak_current: I32?
    streak_best: I32?
    brief: String?
    createdAt: DateTime
    updatedAt: DateTime
}


// ──────────────────────────────────────────────
// Media
// ──────────────────────────────────────────────

node Media {
    slug: String @key
    name: String @index
    kind: enum(book, article, movie, show, podcast, episode, album, paper, video, game, blog, newsletter, website) @index
    status: enum(want, consuming, finished, abandoned)?
    rating: F32?
    url: String?
    published_date: Date?
    brief: String?
    tags: [String]?
    createdAt: DateTime
    updatedAt: DateTime
}


// ──────────────────────────────────────────────
// Provenance & Search
// ──────────────────────────────────────────────

// Artifact = source-of-truth container for any imported content. One node, fat source enum.
// Email/Conversation collapse in here — use thread_id for grouping, kind=email/message for
// type, and InReplyTo edges for threading.
node Artifact {
    slug: String @key
    name: String @index
    kind: enum(message, email, post, document, transcript, recording, meeting-note, photo, calendar-entry, voice-note, chat-export, web-clip) @index
    source: enum(whatsapp, email, slack, telegram, imessage, sms, linkedin, instagram, x, calendar, web, manual, voice, notes-app, readwise, other) @index
    source_ref: String?
    thread_id: String? @index
    url: String?
    content: String?
    blob: Blob?
    content_sha256: String? @index
    timestamp: DateTime @index
    createdAt: DateTime
    updatedAt: DateTime
}

// Immutable. Embedding-driven semantic search.
node Chunk {
    text: String
    chunk_index: I32
    embedding: Vector(3072) @embed("text") @index
    createdAt: DateTime
}


// ──────────────────────────────────────────────
// Edges: Relationships & Roles
// ──────────────────────────────────────────────

edge Knows: Person -> Person {
    context: String?
    since: Date?
}

// Family/partnership structure. Use edge property `relation` to qualify.
edge RelatedToPerson: Person -> Person {
    relation: enum(spouse, partner, parent, child, sibling, grandparent, grandchild, in-law, ex)
}

edge LivesIn: Person -> Place {
    primary: Bool?
    since: Date?
}

edge WorksAt: Person -> Organization {
    role: String?
    since: Date?
    until: Date?
    current: Bool?
}


// ──────────────────────────────────────────────
// Edges: Event Participation
// ──────────────────────────────────────────────

edge AttendedBy: Event -> Person
edge HappenedAt: Event -> Place
edge EventForProject: Event -> Project
// For milestones affecting someone else without them "attending" (e.g. their wedding from afar).
edge EventForPerson: Event -> Person


// ──────────────────────────────────────────────
// Edges: Note → World
// ──────────────────────────────────────────────

edge NoteAboutPerson: Note -> Person
edge NoteAboutProject: Note -> Project
edge NoteAboutArea: Note -> Area
edge NoteAboutPlace: Note -> Place
edge NoteAboutOrganization: Note -> Organization
edge NoteAboutMedia: Note -> Media
edge NoteFromArtifact: Note -> Artifact
edge NoteFromEvent: Note -> Event
edge RelatedNote: Note -> Note
// A Habit motivated by a principle (Note with kind=principle).
edge HabitFromPrinciple: Habit -> Note


// ──────────────────────────────────────────────
// Edges: Action & Structure
// ──────────────────────────────────────────────

edge TaskForPerson: Task -> Person
edge TaskForProject: Task -> Project
edge TaskForArea: Task -> Area
edge TaskForGoal: Task -> Goal
edge TaskFromArtifact: Task -> Artifact
edge TaskFromEvent: Task -> Event
edge TaskDependsOnTask: Task -> Task {
    kind: enum(blocked-by, prerequisite, sequence, waiting-on)?
    reason: String?
}

edge ProjectInArea: Project -> Area
edge ProjectForOrganization: Project -> Organization
edge GoalForArea: Goal -> Area
edge HabitForArea: Habit -> Area
edge HabitForGoal: Habit -> Goal
edge PersonInvolvedInProject: Person -> Project {
    role: String?
}


// ──────────────────────────────────────────────
// Edges: Media
// ──────────────────────────────────────────────

edge MediaAuthoredBy: Media -> Person
edge MediaRecommendedBy: Media -> Person
edge MediaForProject: Media -> Project
edge MediaForArea: Media -> Area
edge MediaPartOf: Media -> Media


// ──────────────────────────────────────────────
// Edges: Provenance
// ──────────────────────────────────────────────

edge MentionsPerson: Artifact -> Person
edge ArtifactFromPerson: Artifact -> Person
edge ArtifactForProject: Artifact -> Project
edge RecordOf: Artifact -> Event
edge InReplyTo: Artifact -> Artifact
edge DerivedFromArtifact: Artifact -> Artifact {
    activity: enum(transcribed, summarized, ocr, imported, clipped, corrected, translated, extracted)
    agent: String?
    model: String?
    confidence: F32?
    createdAt: DateTime
}
edge ChunkOf: Chunk -> Artifact @card(1..1) {
    @unique(src)
}
